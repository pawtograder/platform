{
  "uid": "pawtograder-edge-soak",
  "title": "Pawtograder · Edge Soak / Resilience",
  "tags": ["pawtograder", "soak", "edge"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "annotations": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "ns",
        "label": "Namespace",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(kube_horizontalpodautoscaler_status_current_replicas{horizontalpodautoscaler=\"pawtograder-functions\"}, namespace)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1,
        "current": { "value": "pawtograder-staging", "text": "pawtograder-staging" }
      }
    ]
  },
  "panels": [
    { "type": "row", "title": "Capacity & scaling", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
    {
      "type": "timeseries", "title": "Edge HPA replicas (current / desired / min / max)",
      "datasource": { "type": "prometheus", "uid": "prometheus" }, "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=\"$ns\",horizontalpodautoscaler=\"pawtograder-functions\"}", "legendFormat": "current" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "kube_horizontalpodautoscaler_status_desired_replicas{namespace=\"$ns\",horizontalpodautoscaler=\"pawtograder-functions\"}", "legendFormat": "desired" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "kube_horizontalpodautoscaler_spec_min_replicas{namespace=\"$ns\",horizontalpodautoscaler=\"pawtograder-functions\"}", "legendFormat": "min" },
        { "refId": "D", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "kube_horizontalpodautoscaler_spec_max_replicas{namespace=\"$ns\",horizontalpodautoscaler=\"pawtograder-functions\"}", "legendFormat": "max" }
      ]
    },
    {
      "type": "timeseries", "title": "Edge HPA memory utilization vs target (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" }, "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "100 * sum(container_memory_working_set_bytes{namespace=\"$ns\",container=\"functions\"}) / sum(kube_pod_container_resource_requests{namespace=\"$ns\",container=\"functions\",resource=\"memory\"})", "legendFormat": "avg mem util %" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    { "type": "row", "title": "Memory (the resilience signal)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 } },
    {
      "type": "timeseries", "title": "Per-pod edge memory (MiB) — should plateau, not ramp",
      "datasource": { "type": "prometheus", "uid": "prometheus" }, "gridPos": { "h": 9, "w": 16, "x": 0, "y": 10 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "container_memory_working_set_bytes{namespace=\"$ns\",container=\"functions\"}/1048576", "legendFormat": "{{pod}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(kube_pod_container_resource_limits{namespace=\"$ns\",container=\"functions\",resource=\"memory\"})/1048576", "legendFormat": "pod limit" }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes" }, "overrides": [] }
    },
    {
      "type": "stat", "title": "OOMKills (last 1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" }, "gridPos": { "h": 9, "w": 8, "x": 16, "y": 10 },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name", "orientation": "vertical" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"$ns\",container=\"functions\"}[1h]))", "legendFormat": "fn restarts" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(kube_pod_container_status_last_terminated_reason{namespace=\"$ns\",reason=\"OOMKilled\"} == 1) or vector(0)", "legendFormat": "OOMKilled pods" }
      ]
    },
    { "type": "row", "title": "Worker lifecycle (Loki logs)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 } },
    {
      "type": "timeseries", "title": "Worker events / min — cancels & hard-kills should stay ~0; early-drops are healthy",
      "datasource": { "type": "loki" }, "gridPos": { "h": 9, "w": 24, "x": 0, "y": 20 },
      "targets": [
        { "refId": "A", "datasource": { "type": "loki" }, "expr": "sum(count_over_time({namespace=\"$ns\"} |= \"cancelled by supervisor\" [1m]))", "legendFormat": "cancelled-by-supervisor" },
        { "refId": "B", "datasource": { "type": "loki" }, "expr": "sum(count_over_time({namespace=\"$ns\"} |= \"memory limit reached\" [1m]))", "legendFormat": "memory-limit hard-kill" },
        { "refId": "C", "datasource": { "type": "loki" }, "expr": "sum(count_over_time({namespace=\"$ns\"} |~ \"early.drop|early termination\" [1m]))", "legendFormat": "early-drop (healthy)" }
      ]
    },
    { "type": "row", "title": "Throughput & errors (Loki logs)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 } },
    {
      "type": "timeseries", "title": "Submissions created / min (throughput proxy)",
      "datasource": { "type": "loki" }, "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "targets": [
        { "refId": "A", "datasource": { "type": "loki" }, "expr": "sum(count_over_time({namespace=\"$ns\"} |= \"Created submission\" [1m]))", "legendFormat": "submissions/min" }
      ]
    },
    {
      "type": "timeseries", "title": "Function errors / min",
      "datasource": { "type": "loki" }, "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "targets": [
        { "refId": "A", "datasource": { "type": "loki" }, "expr": "sum(count_over_time({namespace=\"$ns\"} |= \"An unknown error occurred\" [1m]))", "legendFormat": "unknown-error envelope" },
        { "refId": "B", "datasource": { "type": "loki" }, "expr": "sum(count_over_time({namespace=\"$ns\"} |= \"[Error]\" [1m]))", "legendFormat": "logged errors" }
      ]
    }
  ]
}
