{
  "uid": "pawtograder-stack-overview",
  "title": "Pawtograder · Stack Overview",
  "tags": ["pawtograder", "stack"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(kube_pod_info{pod=~\"pawtograder-.*\"}, namespace)",
        "refresh": 1,
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Pods ready",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by(namespace) (kube_pod_status_ready{namespace=~\"$namespace\", pod=~\"pawtograder-.*\", condition=\"true\"})"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 8 }
            ]
          },
          "unit": "none"
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pods restarting (1h)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by(namespace) (increase(kube_pod_container_status_restarts_total{namespace=~\"$namespace\", pod=~\"pawtograder-.*\"}[1h]))"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "none"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Web error rate (5xx, 5m)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(web_http_request_duration_seconds_count{status=~\"5..\"}[5m])) / clamp_min(sum(rate(web_http_request_duration_seconds_count[5m])), 0.001)"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit"
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active submissions",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(pawtograder_active_submissions_active_count)" }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": { "defaults": { "unit": "none" } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "HTTP request rate by service",
      "description": "Per-service request rate. web/auth/kong serve user-facing traffic; storage-api's HTTP pool is a proxy for upstream MinIO calls (it doesn't export a request-count histogram).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "web",
          "legendFormat": "web",
          "expr": "sum(rate(web_http_request_duration_seconds_count[1m]))"
        },
        {
          "refId": "kong",
          "legendFormat": "kong (proxy)",
          "expr": "sum(rate(kong_http_requests_total[1m]))"
        },
        {
          "refId": "auth",
          "legendFormat": "auth (gotrue)",
          "expr": "sum(rate(http_status_codes_total{job=\"pawtograder-auth\"}[1m]))"
        },
        {
          "refId": "storage",
          "legendFormat": "storage-api (http pool)",
          "expr": "sum(rate(storage_api_http_pool_requests[1m]))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "P95 latency by service",
      "description": "P95 over 5 min. kong's bucket is per-request total latency; auth uses OTel http_server_duration_milliseconds.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "web",
          "legendFormat": "web",
          "expr": "histogram_quantile(0.95, sum by(le)(rate(web_http_request_duration_seconds_bucket[5m])))"
        },
        {
          "refId": "kong",
          "legendFormat": "kong (proxy)",
          "expr": "histogram_quantile(0.95, sum by(le)(rate(kong_request_latency_ms_bucket[5m]))) / 1000"
        },
        {
          "refId": "auth",
          "legendFormat": "auth (gotrue)",
          "expr": "histogram_quantile(0.95, sum by(le)(rate(http_server_duration_milliseconds_bucket{job=\"pawtograder-auth\"}[5m]))) / 1000"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Memory by pod (RSS)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{pod}}",
          "expr": "sum by(pod) (container_memory_working_set_bytes{namespace=~\"$namespace\", pod=~\"pawtograder-.*\", container!=\"\", container!=\"POD\"})"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "CPU by pod",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{pod}}",
          "expr": "sum by(pod) (rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\", pod=~\"pawtograder-.*\", container!=\"\", container!=\"POD\"}[1m]))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "min": 0 } }
    },
    {
      "id": 30,
      "type": "table",
      "title": "Recent restarts (24h)",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "instant": true,
          "expr": "topk(10, sum by(pod, namespace) (increase(kube_pod_container_status_restarts_total{namespace=~\"$namespace\", pod=~\"pawtograder-.*\"}[24h])))"
        }
      ]
    }
  ]
}
