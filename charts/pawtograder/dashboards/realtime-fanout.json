{
  "uid": "pawtograder-realtime",
  "title": "Pawtograder · Realtime Fanout",
  "tags": ["pawtograder", "realtime"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active connections",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "sum(realtime_connected)" }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Channels joined",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "sum(realtime_channels)" }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Server broadcast rate (1m)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(web_realtime_broadcast_total[1m]))" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "WS messages out / s",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(realtime_channel_events[1m]))" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "WebSocket connection churn",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "legendFormat": "joined / s", "expr": "sum(rate(realtime_joined_total[1m]))" },
        { "refId": "B", "legendFormat": "left / s", "expr": "sum(rate(realtime_left_total[1m]))" },
        { "refId": "C", "legendFormat": "errored / s", "expr": "sum(rate(realtime_disconnected_total[1m]))" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Connections per replica",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{pod}}",
          "expr": "realtime_connected"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Server-initiated broadcasts by channel class",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{channel_class}}",
          "expr": "sum by(channel_class)(rate(web_realtime_broadcast_total[1m]))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Realtime Erlang VM scheduler load",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{pod}} sched {{scheduler_id}}",
          "expr": "erlang_vm_scheduler_utilization"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Realtime memory",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{pod}} processes",
          "expr": "erlang_vm_memory_bytes_total{kind=\"processes\"}"
        },
        {
          "refId": "B",
          "legendFormat": "{{pod}} binary",
          "expr": "erlang_vm_memory_bytes_total{kind=\"binary\"}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ]
}
